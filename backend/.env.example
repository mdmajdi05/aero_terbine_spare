# ============================================================
# AeroTurbineSpare Backend — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ── Server ───────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# ── Database — Default: Neon PostgreSQL (serverless) ─────────
# Get your connection string from https://neon.tech/
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.us-east-1.aws.neon.tech/aeroturbinespare?sslmode=require"

# Database type hint for the repository layer
# Options: neon | postgres | mysql | mongodb
# Changing this only changes connection behavior; you must also update prisma/schema.prisma
DB_TYPE=neon

# Connection pool (important for serverless Neon)
DB_POOL_MIN=1
DB_POOL_MAX=10
DB_CONNECT_TIMEOUT_MS=10000

# ── Auth / JWT ────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_256BIT_SECRET_STRING
JWT_REFRESH_SECRET=CHANGE_ME_TO_ANOTHER_RANDOM_256BIT_STRING
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── SMTP / Email ──────────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_sendgrid_api_key
EMAIL_FROM="AeroTurbineSpare <noreply@aeroturbinespare.com>"
RFQ_NOTIFY_EMAIL=rfq@aeroturbinespare.com

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RFQ_RATE_LIMIT_MAX=10

# ── File Upload ───────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# ── Cloudinary (Blog Media) ───────────────────────────────────
# Get these from https://cloudinary.com → Dashboard → API Keys
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Backup / Export ───────────────────────────────────────────
BACKUP_DIR=./backups
BACKUP_ENCRYPTION_KEY=CHANGE_ME_32_CHARS_BACKUP_KEY_HERE

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=./logs
