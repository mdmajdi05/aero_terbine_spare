// ============================================================
// AeroTurbineSpare — Prisma Schema (Neon PostgreSQL default)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Neon uses connection pooling via PgBouncer on port 5432
  // directUrl for migrations (bypasses PgBouncer)
  directUrl = env("DIRECT_DATABASE_URL")
}

// ── Enums ─────────────────────────────────────────────────────

enum UserRole {
  SuperAdmin
  Admin
  ContentManager
  Trader
  User
}

enum Condition {
  New
  Used
  Refurbished
  Overhauled
}

enum StockStatus {
  InStock
  OnOrder
  Obsolete
  Limited
}

enum RFQUrgency {
  Standard
  Urgent
  Critical
}

enum RFQStatus {
  Pending
  UnderReview
  Quoted
  Accepted
  Ordered
  Cancelled
}

enum OrderStatus {
  Processing
  Confirmed
  InTransit
  Delivered
  Cancelled
}

enum InventoryStatus {
  Pending
  Processing
  Complete
  Rejected
}

enum AuditStatus {
  Success
  Warning
  Failed
}

enum BackupType {
  manual
  scheduled
}

enum BackupStatus {
  Running
  Complete
  Failed
}

// ── Models ────────────────────────────────────────────────────

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String    @map("password_hash")
  fullName     String    @map("full_name")
  company      String
  cageCode     String?   @map("cage_code")
  phone        String
  role         UserRole  @default(User)
  country      String    @default("United States")
  address      String?
  avatarUrl    String?   @map("avatar_url")
  isActive     Boolean   @default(true) @map("is_active")
  lastLogin    DateTime? @map("last_login")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  rfqs           RFQ[]
  orders         Order[]
  savedParts     SavedPart[]
  inventorySubs  InventorySubmission[]
  auditLogs      AuditLog[]
  submittedParts Part[]                @relation("PartSubmitter")
  blogPosts      BlogPost[]            @relation("BlogAuthor")
  blogMedia      BlogMedia[]           @relation("BlogMediaUploader")
  blogComments   BlogComment[]         @relation("BlogCommenter")

  @@map("users")
}

model Part {
  id                String      @id @default(uuid())
  nsn               String      @unique
  cage              String
  partNumber        String      @unique @map("part_number")
  description       String
  shortDescription  String      @map("short_description")
  fsg               String
  fsc               String
  category          String
  manufacturer      String
  condition         Condition   @default(New)
  stockStatus       StockStatus @default(InStock) @map("stock_status")
  quantityAvailable Int         @default(0) @map("quantity_available")
  unitPrice         Decimal     @default(0) @map("unit_price") @db.Decimal(12, 2)
  currency          String      @default("USD")
  datasheetUrl      String?     @map("datasheet_url")
  imageUrl          String?     @map("image_url")
  crossReferences   String[]    @map("cross_references")
  specifications    Json        @default("{}")
  tags              String[]    @default([])

  submittedById String? @map("submitted_by_id")
  submittedBy   User?   @relation("PartSubmitter", fields: [submittedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  rfqItems   RFQItem[]
  orderItems OrderItem[]
  savedParts SavedPart[]

  @@index([nsn])
  @@index([cage])
  @@index([partNumber])
  @@index([category])
  @@index([fsg])
  @@map("parts")
}

model RFQ {
  id                  String     @id @default(uuid())
  userId              String?    @map("user_id")
  companyName         String     @map("company_name")
  contactName         String     @map("contact_name")
  email               String
  phone               String
  urgency             RFQUrgency @default(Standard)
  deliveryDeadline    DateTime   @map("delivery_deadline")
  shippingAddress     String     @map("shipping_address")
  shippingCountry     String     @map("shipping_country")
  incoterms           String     @default("EXW")
  specialInstructions String?    @map("special_instructions")
  attachmentUrl       String?    @map("attachment_url")
  status              RFQStatus  @default(Pending)
  quoteAmount         Decimal?   @map("quote_amount") @db.Decimal(12, 2)
  quoteCurrency       String?    @map("quote_currency")
  quotedAt            DateTime?  @map("quoted_at")
  quotedById          String?    @map("quoted_by_id")
  estimatedDelivery   DateTime?  @map("estimated_delivery")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user  User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  items RFQItem[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("rfqs")
}

model RFQItem {
  id          String   @id @default(uuid())
  rfqId       String   @map("rfq_id")
  partId      String?  @map("part_id")
  partNumber  String   @map("part_number")
  nsn         String
  description String
  quantity    Int
  targetPrice Decimal? @map("target_price") @db.Decimal(12, 2)
  condition   String?

  rfq  RFQ   @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  part Part? @relation(fields: [partId], references: [id], onDelete: SetNull)

  @@map("rfq_items")
}

model Order {
  id              String      @id @default(uuid())
  rfqId           String?     @map("rfq_id")
  userId          String?     @map("user_id")
  subtotal        Decimal     @db.Decimal(12, 2)
  tax             Decimal     @db.Decimal(12, 2)
  shippingCost    Decimal     @map("shipping_cost") @db.Decimal(12, 2)
  totalAmount     Decimal     @map("total_amount") @db.Decimal(12, 2)
  currency        String      @default("USD")
  status          OrderStatus @default(Processing)
  trackingNumber  String?     @map("tracking_number")
  carrier         String?
  shippingAddress String      @map("shipping_address")
  invoiceUrl      String?     @map("invoice_url")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user  User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  items OrderItem[]

  @@index([userId])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id          String  @id @default(uuid())
  orderId     String  @map("order_id")
  partId      String? @map("part_id")
  partNumber  String  @map("part_number")
  description String
  quantity    Int
  unitPrice   Decimal @map("unit_price") @db.Decimal(12, 2)
  totalPrice  Decimal @map("total_price") @db.Decimal(12, 2)

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  part  Part? @relation(fields: [partId], references: [id], onDelete: SetNull)

  @@map("order_items")
}

model SavedPart {
  id      String   @id @default(uuid())
  userId  String   @map("user_id")
  partId  String   @map("part_id")
  savedAt DateTime @default(now()) @map("saved_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  part Part @relation(fields: [partId], references: [id], onDelete: Cascade)

  @@unique([userId, partId])
  @@map("saved_parts")
}

model InventorySubmission {
  id           String          @id @default(uuid())
  userId       String?         @map("user_id")
  companyName  String          @map("company_name")
  contactEmail String          @map("contact_email")
  fileName     String          @map("file_name")
  fileUrl      String?         @map("file_url")
  partCount    Int?            @map("part_count")
  status       InventoryStatus @default(Pending)
  notes        String?

  submittedAt DateTime  @default(now()) @map("submitted_at")
  processedAt DateTime? @map("processed_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("inventory_submissions")
}

model AuditLog {
  id         String      @id @default(uuid())
  userId     String      @map("user_id")
  userEmail  String      @map("user_email")
  userRole   UserRole    @map("user_role")
  action     String
  resource   String
  resourceId String?     @map("resource_id")
  details    String?
  ipAddress  String?     @map("ip_address")
  userAgent  String?     @map("user_agent")
  status     AuditStatus @default(Success)

  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model BackupRecord {
  id          String       @id @default(uuid())
  triggeredBy String       @map("triggered_by")
  type        BackupType   @default(manual)
  status      BackupStatus @default(Running)
  sizeBytes   BigInt?      @map("size_bytes")
  downloadUrl String?      @map("download_url")

  createdAt   DateTime  @default(now()) @map("created_at")
  completedAt DateTime? @map("completed_at")

  @@map("backup_records")
}

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String   @map("updated_by")

  @@map("system_settings")
}

model ExcelFeed {
  id           String   @id @default(uuid())
  filename     String
  status       String   @default("active") // active | paused
  type         String? // "product" | "part"
  categorySlug String?  @map("category_slug")
  categoryName String?  @map("category_name")
  industrySlug String?  @map("industry_slug")
  columns      Json     @default("[]")
  rowCount     Int      @default(0) @map("row_count")
  data         Json     @default("[]")
  uploadedBy   String   @map("uploaded_by")
  uploadedAt   DateTime @default(now()) @map("uploaded_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("excel_feeds")
}

model NavCategory {
  id           String  @id @default(uuid())
  name         String
  slug         String  @unique
  type         String // "fsg" | "industry" | "product" | "part"
  parentId     String? // for product/part: references industry slug
  description  String?
  icon         String?
  manufacturer String?
  partCount    Int     @default(0) @map("part_count")
  sortOrder    Int     @default(0) @map("sort_order")

  // Industry-specific
  longDescription String?  @map("long_description")
  keyParts        String[] @default([]) @map("key_parts")
  clients         String[] @default([])

  // FSG-specific
  fsgCode String? @map("fsg_code")
  fscCode String? @map("fsc_code")

  // Links product/part to industry IDs
  industryIds String[] @default([]) @map("industry_ids")

  // Display & page configuration (JSON — extendable)
  cardConfig Json @default("{}") @map("card_config")
  pageConfig Json @default("{}") @map("page_config")

  // Relationship
  items CategoryItem[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([type])
  @@index([parentId])
  @@map("nav_categories")
}

model CategoryItem {
  id            String      @id @default(uuid())
  navCategoryId String      @map("nav_category_id")
  category      NavCategory @relation(fields: [navCategoryId], references: [id], onDelete: Cascade)
  title         String
  slug          String      @unique
  description   String?
  image         String?
  link          String? // internal slug or external URL
  data          Json        @default("{}") // flexible fields from Excel columns
  sortOrder     Int         @default(0) @map("sort_order")
  isActive      Boolean     @default(true) @map("is_active")
  cardConfig    Json        @default("{}") @map("card_config") // per-item override

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([navCategoryId])
  @@index([slug])
  @@index([isActive])
  @@map("category_items")
}

// ── Blog System ───────────────────────────────────────────────

enum PostStatus {
  Draft
  Published
  Scheduled
  Archived
}

model BlogPost {
  id              String     @id @default(uuid())
  title           String
  slug            String     @unique
  excerpt         String?
  content         String     @db.Text
  coverImage      String?    @map("cover_image")
  coverAlt        String?    @map("cover_alt")
  status          PostStatus @default(Draft)
  publishedAt     DateTime?  @map("published_at")
  scheduledAt     DateTime?  @map("scheduled_at")
  deletedAt       DateTime?  @map("deleted_at")
  metaTitle       String?    @map("meta_title")
  metaDesc        String?    @map("meta_desc")
  focusKw         String?    @map("focus_kw")
  canonicalUrl    String?    @map("canonical_url")
  robotsIndex     Boolean    @default(true) @map("robots_index")
  robotsFollow    Boolean    @default(true) @map("robots_follow")
  schemaOverrides Json?      @map("schema_overrides")
  customJsonLd    String?    @map("custom_json_ld")
  seoScore        Int        @default(0) @map("seo_score")
  viewCount       Int        @default(0) @map("view_count")

  authorId String @map("author_id")
  author   User   @relation("BlogAuthor", fields: [authorId], references: [id], onDelete: Restrict)

  categories BlogCategory[]    @relation("PostCategories")
  tags       BlogTag[]         @relation("PostTags")
  comments   BlogComment[]
  versions   BlogPostVersion[] @relation("PostVersions")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([slug])
  @@index([status])
  @@index([authorId])
  @@index([publishedAt])
  @@map("blog_posts")
}

model BlogCategory {
  id          String     @id @default(uuid())
  name        String     @unique
  slug        String     @unique
  description String?
  posts       BlogPost[] @relation("PostCategories")
  createdAt   DateTime   @default(now()) @map("created_at")

  @@map("blog_categories")
}

model BlogTag {
  id        String     @id @default(uuid())
  name      String     @unique
  slug      String     @unique
  posts     BlogPost[] @relation("PostTags")
  createdAt DateTime   @default(now()) @map("created_at")

  @@map("blog_tags")
}

model BlogMedia {
  id           String   @id @default(uuid())
  url          String // Cloudinary secure URL
  cloudinaryId String   @map("cloudinary_id") // e.g. "aeroturbinespare/blog/abc123"
  filename     String
  mimeType     String   @map("mime_type")
  size         Int
  width        Int?
  height       Int?
  alt          String?
  uploadedById String   @map("uploaded_by_id")
  uploader     User     @relation("BlogMediaUploader", fields: [uploadedById], references: [id], onDelete: Restrict)
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("blog_media")
}

model BlogComment {
  id       String  @id @default(uuid())
  content  String
  approved Boolean @default(false)

  postId String   @map("post_id")
  post   BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  authorId String? @map("author_id")
  author   User?   @relation("BlogCommenter", fields: [authorId], references: [id], onDelete: SetNull)

  guestName  String? @map("guest_name")
  guestEmail String? @map("guest_email")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([postId])
  @@index([approved])
  @@map("blog_comments")
}

model BlogPostVersion {
  id              String   @id @default(uuid())
  postId          String   @map("post_id")
  post            BlogPost @relation("PostVersions", fields: [postId], references: [id], onDelete: Cascade)
  version         Int
  title           String
  slug            String
  content         String   @db.Text
  excerpt         String?
  coverImage      String?  @map("cover_image")
  coverAlt        String?  @map("cover_alt")
  metaTitle       String?  @map("meta_title")
  metaDesc        String?  @map("meta_desc")
  focusKw         String?  @map("focus_kw")
  canonicalUrl    String?  @map("canonical_url")
  robotsIndex     Boolean  @default(true) @map("robots_index")
  robotsFollow    Boolean  @default(true) @map("robots_follow")
  schemaOverrides Json?    @map("schema_overrides")
  customJsonLd    String?  @map("custom_json_ld")
  categoryIds     String?
  tagIds          String?
  createdBy       String   @map("created_by")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([postId])
  @@map("blog_post_versions")
}

model BlogRedirect {
  id        String   @id @default(uuid())
  fromSlug  String   @unique @map("from_slug")
  toSlug    String   @map("to_slug")
  type      Int      @default(301)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("blog_redirects")
}

model PageSchema {
  pageKey    String   @id
  label      String
  schemaJson Json?
  faqItems   Json?
  updatedAt  DateTime @updatedAt @map("updated_at")
  updatedBy  String   @map("updated_by")

  @@map("page_schemas")
}
