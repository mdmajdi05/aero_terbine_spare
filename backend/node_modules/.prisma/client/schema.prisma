// ============================================================
// AeroTurbineSpare — Prisma Schema (Neon PostgreSQL default)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Neon uses connection pooling via PgBouncer on port 5432
  // directUrl for migrations (bypasses PgBouncer)
  directUrl = env("DIRECT_DATABASE_URL")
}

// ── Enums ─────────────────────────────────────────────────────

enum UserRole {
  SuperAdmin
  Admin
  Trader
  User
}

enum Condition {
  New
  Used
  Refurbished
  Overhauled
}

enum StockStatus {
  InStock
  OnOrder
  Obsolete
  Limited
}

enum RFQUrgency {
  Standard
  Urgent
  Critical
}

enum RFQStatus {
  Pending
  UnderReview
  Quoted
  Accepted
  Ordered
  Cancelled
}

enum OrderStatus {
  Processing
  Confirmed
  InTransit
  Delivered
  Cancelled
}

enum InventoryStatus {
  Pending
  Processing
  Complete
  Rejected
}

enum AuditStatus {
  Success
  Warning
  Failed
}

enum BackupType {
  manual
  scheduled
}

enum BackupStatus {
  Running
  Complete
  Failed
}

// ── Models ────────────────────────────────────────────────────

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String    @map("password_hash")
  fullName     String    @map("full_name")
  company      String
  cageCode     String?   @map("cage_code")
  phone        String
  role         UserRole  @default(User)
  country      String    @default("United States")
  address      String?
  avatarUrl    String?   @map("avatar_url")
  isActive     Boolean   @default(true) @map("is_active")
  lastLogin    DateTime? @map("last_login")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  rfqs          RFQ[]
  orders        Order[]
  savedParts    SavedPart[]
  inventorySubs InventorySubmission[]
  auditLogs     AuditLog[]

  @@map("users")
}

model Part {
  id                String      @id @default(uuid())
  nsn               String      @unique
  cage              String
  partNumber        String      @unique @map("part_number")
  description       String
  shortDescription  String      @map("short_description")
  fsg               String
  fsc               String
  category          String
  manufacturer      String
  condition         Condition   @default(New)
  stockStatus       StockStatus @default(InStock) @map("stock_status")
  quantityAvailable Int         @default(0) @map("quantity_available")
  unitPrice         Decimal     @default(0) @map("unit_price") @db.Decimal(12, 2)
  currency          String      @default("USD")
  datasheetUrl      String?     @map("datasheet_url")
  imageUrl          String?     @map("image_url")
  crossReferences   String[]    @map("cross_references")
  specifications    Json        @default("{}")
  tags              String[]    @default([])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  rfqItems   RFQItem[]
  orderItems OrderItem[]
  savedParts SavedPart[]

  @@index([nsn])
  @@index([cage])
  @@index([partNumber])
  @@index([category])
  @@index([fsg])
  @@map("parts")
}

model RFQ {
  id                  String     @id @default(uuid())
  userId              String?    @map("user_id")
  companyName         String     @map("company_name")
  contactName         String     @map("contact_name")
  email               String
  phone               String
  urgency             RFQUrgency @default(Standard)
  deliveryDeadline    DateTime   @map("delivery_deadline")
  shippingAddress     String     @map("shipping_address")
  shippingCountry     String     @map("shipping_country")
  incoterms           String     @default("EXW")
  specialInstructions String?    @map("special_instructions")
  attachmentUrl       String?    @map("attachment_url")
  status              RFQStatus  @default(Pending)
  quoteAmount         Decimal?   @map("quote_amount") @db.Decimal(12, 2)
  quoteCurrency       String?    @map("quote_currency")
  quotedAt            DateTime?  @map("quoted_at")
  quotedById          String?    @map("quoted_by_id")
  estimatedDelivery   DateTime?  @map("estimated_delivery")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user  User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  items RFQItem[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("rfqs")
}

model RFQItem {
  id          String   @id @default(uuid())
  rfqId       String   @map("rfq_id")
  partId      String?  @map("part_id")
  partNumber  String   @map("part_number")
  nsn         String
  description String
  quantity    Int
  targetPrice Decimal? @map("target_price") @db.Decimal(12, 2)
  condition   String?

  rfq  RFQ   @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  part Part? @relation(fields: [partId], references: [id], onDelete: SetNull)

  @@map("rfq_items")
}

model Order {
  id              String      @id @default(uuid())
  rfqId           String?     @map("rfq_id")
  userId          String?     @map("user_id")
  subtotal        Decimal     @db.Decimal(12, 2)
  tax             Decimal     @db.Decimal(12, 2)
  shippingCost    Decimal     @map("shipping_cost") @db.Decimal(12, 2)
  totalAmount     Decimal     @map("total_amount") @db.Decimal(12, 2)
  currency        String      @default("USD")
  status          OrderStatus @default(Processing)
  trackingNumber  String?     @map("tracking_number")
  carrier         String?
  shippingAddress String      @map("shipping_address")
  invoiceUrl      String?     @map("invoice_url")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user  User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  items OrderItem[]

  @@index([userId])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id          String  @id @default(uuid())
  orderId     String  @map("order_id")
  partId      String? @map("part_id")
  partNumber  String  @map("part_number")
  description String
  quantity    Int
  unitPrice   Decimal @map("unit_price") @db.Decimal(12, 2)
  totalPrice  Decimal @map("total_price") @db.Decimal(12, 2)

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  part  Part? @relation(fields: [partId], references: [id], onDelete: SetNull)

  @@map("order_items")
}

model SavedPart {
  id      String   @id @default(uuid())
  userId  String   @map("user_id")
  partId  String   @map("part_id")
  savedAt DateTime @default(now()) @map("saved_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  part Part @relation(fields: [partId], references: [id], onDelete: Cascade)

  @@unique([userId, partId])
  @@map("saved_parts")
}

model InventorySubmission {
  id           String          @id @default(uuid())
  userId       String?         @map("user_id")
  companyName  String          @map("company_name")
  contactEmail String          @map("contact_email")
  fileName     String          @map("file_name")
  fileUrl      String?         @map("file_url")
  partCount    Int?            @map("part_count")
  status       InventoryStatus @default(Pending)
  notes        String?

  submittedAt DateTime  @default(now()) @map("submitted_at")
  processedAt DateTime? @map("processed_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("inventory_submissions")
}

model AuditLog {
  id         String      @id @default(uuid())
  userId     String      @map("user_id")
  userEmail  String      @map("user_email")
  userRole   UserRole    @map("user_role")
  action     String
  resource   String
  resourceId String?     @map("resource_id")
  details    String?
  ipAddress  String?     @map("ip_address")
  userAgent  String?     @map("user_agent")
  status     AuditStatus @default(Success)

  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model BackupRecord {
  id          String       @id @default(uuid())
  triggeredBy String       @map("triggered_by")
  type        BackupType   @default(manual)
  status      BackupStatus @default(Running)
  sizeBytes   BigInt?      @map("size_bytes")
  downloadUrl String?      @map("download_url")

  createdAt   DateTime  @default(now()) @map("created_at")
  completedAt DateTime? @map("completed_at")

  @@map("backup_records")
}

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String   @map("updated_by")

  @@map("system_settings")
}
