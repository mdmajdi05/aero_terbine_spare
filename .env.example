# ─────────────────────────────────────────────────────────────
# AeroTurbineSpare — Frontend Environment Variables
# Copy to .env.local and fill in real values.
# ─────────────────────────────────────────────────────────────

# Set to "true" to use mock data (no backend required)
# Set to "false" to connect to the real Express backend
NEXT_PUBLIC_USE_MOCK=false

# Base URL of the Express backend API (used when USE_MOCK=false)
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# Optional: site URL for canonical links / OG metadata
NEXT_PUBLIC_SITE_URL=https://aeroturbinespare.com
